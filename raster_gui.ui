<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1280</width>
    <height>720</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Raster Controller</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout_Main">
    <item>
     <layout class="QHBoxLayout" name="horizontalLayout_Top">
      <item>
       <widget class="QLabel" name="label_timer">
        <property name="text">
         <string>Delay (s):</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QDoubleSpinBox" name="sleepTimer">
        <property name="decimals">
         <number>3</number>
        </property>
        <property name="maximum">
         <double>60.0</double>
        </property>
        <property name="singleStep">
         <double>0.05</double>
        </property>
       </widget>
      </item>
      <item><widget class="Line" name="line_v3"><property name="orientation"><enum>Qt::Vertical</enum></property></widget></item>
      
      <item>
       <widget class="QCheckBox" name="flip_x_checkbox">
        <property name="toolTip">
         <string>Flips the CAMERA image horizontally (display only). Does NOT change the scan path or motor directions.</string>
        </property>
        <property name="text">
         <string>Flip cam X</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="flip_y_checkbox">
        <property name="toolTip">
         <string>Flips the CAMERA image vertically (display only). Does NOT change the scan path or motor directions.</string>
        </property>
        <property name="text">
         <string>Flip cam Y</string>
        </property>
       </widget>
      </item>
      <item>
       <spacer name="horizontalSpacer">
        <property name="orientation">
         <enum>Qt::Horizontal</enum>
        </property>
        <property name="sizeHint" stdset="0">
         <size>
          <width>40</width>
          <height>20</height>
         </size>
        </property>
       </spacer>
      </item>
     </layout>
    </item>
    
    <item>
     <widget class="QSplitter" name="splitter">
      <property name="orientation">
       <enum>Qt::Horizontal</enum>
      </property>
      
      <widget class="QTabWidget" name="tabWidget">
       <property name="currentIndex">
        <number>1</number>
       </property>
       <property name="minimumSize">
        <size>
         <width>400</width>
         <height>0</height>
        </size>
       </property>
       
       <widget class="QWidget" name="tab">
        <attribute name="title">
         <string>Automatic Controls</string>
        </attribute>
        <layout class="QVBoxLayout" name="autoLayout">
         <item>
          <layout class="QHBoxLayout" name="autoButtonsLayout">
           <item>
            <widget class="QPushButton" name="path_button">
             <property name="styleSheet">
              <string notr="true">background-color: rgb(255, 251, 181);</string>
             </property>
             <property name="text">
              <string>Preview Path</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="start_button">
             <property name="styleSheet">
              <string notr="true">background-color: rgb(111, 218, 129);</string>
             </property>
             <property name="text">
              <string>Auto Raster</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="stop_button">
             <property name="styleSheet">
              <string notr="true">background-color: rgb(255, 118, 84);</string>
             </property>
             <property name="text">
              <string>Stop</string>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         <item>
          <layout class="QHBoxLayout" name="autoModeLayout">
           <item>
            <widget class="QCheckBox" name="raster_continuous_checkbox">
             <property name="text">
              <string>Continuous</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="raster_step_button">
             <property name="text">
              <string>Step</string>
             </property>
             <property name="enabled">
              <bool>false</bool>
             </property>
            </widget>
           </item>
           <item>
            <spacer name="autoModeSpacer">
             <property name="orientation"><enum>Qt::Horizontal</enum></property>
             <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
            </spacer>
           </item>
          </layout>
         </item>
         <item>
          <widget class="QPushButton" name="clearAll">
           <property name="styleSheet">
            <string notr="true">background-color: rgb(255, 118, 84);</string>
           </property>
           <property name="text">
            <string>Clear All Raster Points</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QCheckBox" name="checkBox_2">
           <property name="text">
            <string>Save position history</string>
           </property>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_steps">
           <property name="title">
            <string>Raster Step Size</string>
           </property>
           <layout class="QGridLayout" name="grid_steps">
            <item row="0" column="0"><widget class="QLabel" name="lxstep"><property name="text"><string>Step x (image px):</string></property></widget></item>
            <item row="0" column="1"><widget class="QDoubleSpinBox" name="xstep"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.1</double></property><property name="value"><double>0.01</double></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="lystep"><property name="text"><string>Step y (image px):</string></property></widget></item>
            <item row="1" column="1"><widget class="QDoubleSpinBox" name="ystep"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.1</double></property><property name="value"><double>0.01</double></property></widget></item>
           </layout>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_pattern">
           <property name="title">
            <string>Raster Pattern</string>
           </property>
           <layout class="QVBoxLayout" name="patternLayout">
            <item>
             <widget class="QComboBox" name="alg_choice">
              <item><property name="text"><string>Square Raster X</string></property></item>
              <item><property name="text"><string>Square Raster Y</string></property></item>
              <item><property name="text"><string>Spiral Raster</string></property></item>
              <item><property name="text"><string>Convex Hull Raster</string></property></item>
             </widget>
            </item>
            <item>
             <widget class="QCheckBox" name="show_direction_checkbox">
              <property name="text">
               <string>Show rastering direction</string>
              </property>
             </widget>
            </item>
           </layout>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_bounds">
           <property name="toolTip">
            <string>The scan region for ALL patterns: square fill, spiral clip region, and convex-hull grid extent -- not just the square raster. Values are camera image pixels (target space); calibration maps them to motor units.</string>
           </property>
           <property name="title">
            <string>Scan Bounds (image px)</string>
           </property>
           <layout class="QGridLayout" name="grid_bounds">
            <item row="0" column="0"><widget class="QLabel" name="lxlow"><property name="text"><string>x lower:</string></property></widget></item>
            <item row="0" column="1"><widget class="QDoubleSpinBox" name="xlow"><property name="decimals"><number>5</number></property><property name="minimum"><double>-1000.0</double></property><property name="singleStep"><double>0.01</double></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="lxhigh"><property name="text"><string>x upper:</string></property></widget></item>
            <item row="1" column="1"><widget class="QDoubleSpinBox" name="xhigh"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.01</double></property><property name="value"><double>3.0</double></property></widget></item>
            <item row="2" column="0"><widget class="QLabel" name="lylow"><property name="text"><string>y lower:</string></property></widget></item>
            <item row="2" column="1"><widget class="QDoubleSpinBox" name="ylow"><property name="decimals"><number>5</number></property><property name="minimum"><double>-1000.0</double></property><property name="singleStep"><double>0.01</double></property></widget></item>
            <item row="3" column="0"><widget class="QLabel" name="lyhigh"><property name="text"><string>y upper:</string></property></widget></item>
            <item row="3" column="1"><widget class="QDoubleSpinBox" name="yhigh"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.01</double></property><property name="value"><double>3.0</double></property></widget></item>
            <item row="4" column="0" colspan="2">
             <widget class="QPushButton" name="bound_button">
              <property name="styleSheet"><string notr="true">background-color: rgb(255, 251, 181);</string></property>
              <property name="toolTip"><string>Draw the scan-bounds box AND make the controller reject RASTER + go-to-site moves outside it (the calibrated target-space path). Manual "Move to Position"/jog use separate motor limits and are NOT affected. Updates live as you edit; click again to clear + disable.</string></property>
              <property name="text"><string>Enforce Bounds</string></property>
             </widget>
            </item>
           </layout>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_spiral">
           <property name="title">
            <string>Spiral Raster (image px / rad)</string>
           </property>
           <layout class="QGridLayout" name="grid_spiral">
            <item row="0" column="0"><widget class="QLabel" name="lrad"><property name="text"><string>Radius (image px):</string></property></widget></item>
            <item row="0" column="1"><widget class="QDoubleSpinBox" name="radius_spiral"><property name="decimals"><number>5</number></property><property name="minimum"><double>0.0</double></property><property name="singleStep"><double>0.01</double></property><property name="value"><double>0.05</double></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="lradstep"><property name="text"><string>Rad step (image px):</string></property></widget></item>
            <item row="1" column="1"><widget class="QDoubleSpinBox" name="step_spiral"><property name="decimals"><number>5</number></property><property name="minimum"><double>0.0</double></property><property name="singleStep"><double>0.001</double></property><property name="value"><double>0.008</double></property></widget></item>
            <item row="2" column="0"><widget class="QLabel" name="langstep"><property name="text"><string>Angle step (rad):</string></property></widget></item>
            <item row="2" column="1"><widget class="QDoubleSpinBox" name="angle_spiral"><property name="decimals"><number>5</number></property><property name="minimum"><double>0.0</double></property><property name="singleStep"><double>0.01</double></property><property name="value"><double>0.1</double></property></widget></item>
            <item row="3" column="0"><widget class="QLabel" name="langchange"><property name="text"><string>Ang change (rad):</string></property></widget></item>
            <item row="3" column="1"><widget class="QDoubleSpinBox" name="ang_change"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.001</double></property><property name="value"><double>0.05</double></property></widget></item>
            <item row="4" column="0"><widget class="QLabel" name="lspiralcx"><property name="text"><string>Center x (image px):</string></property></widget></item>
            <item row="4" column="1"><widget class="QDoubleSpinBox" name="spiral_cx"><property name="toolTip"><string>Spiral origin X (target/plot units). Independent of the scan bounds; the spiral is still clipped to the bounds.</string></property><property name="decimals"><number>5</number></property><property name="minimum"><double>-100.0</double></property><property name="maximum"><double>100.0</double></property><property name="singleStep"><double>0.01</double></property><property name="value"><double>1.5</double></property></widget></item>
            <item row="5" column="0"><widget class="QLabel" name="lspiralcy"><property name="text"><string>Center y (image px):</string></property></widget></item>
            <item row="5" column="1"><widget class="QDoubleSpinBox" name="spiral_cy"><property name="toolTip"><string>Spiral origin Y (target/plot units). Independent of the scan bounds; the spiral is still clipped to the bounds.</string></property><property name="decimals"><number>5</number></property><property name="minimum"><double>-100.0</double></property><property name="maximum"><double>100.0</double></property><property name="singleStep"><double>0.01</double></property><property name="value"><double>1.5</double></property></widget></item>
           </layout>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="save_button">
           <property name="styleSheet">
            <string notr="true">background-color: rgb(255, 251, 181);</string>
           </property>
           <property name="text">
            <string>Save and Clear</string>
           </property>
          </widget>
         </item>
         <item><spacer name="autoBottomSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer></item>
        </layout>
       </widget>
       
       <widget class="QWidget" name="tab_2">
        <attribute name="title">
         <string>Manual Controls</string>
        </attribute>
        <layout class="QVBoxLayout" name="manualLayout">
         <item>
          <layout class="QHBoxLayout" name="manualTopButtons">
           <item>
             <widget class="QPushButton" name="resetButton">
               <property name="text"><string>Reset</string></property>
               <property name="maximumWidth"><number>60</number></property>
             </widget>
           </item>
           <item>
             <widget class="QPushButton" name="calibrateButton">
               <property name="text"><string>Calibrate (Affine)</string></property>
               <property name="sizePolicy">
                 <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                 </sizepolicy>
               </property>
             </widget>
           </item>
           <item>
             <widget class="QPushButton" name="useold">
               <property name="text"><string>Revert to Last</string></property>
               <property name="toolTip"><string>Re-load the last saved or loaded calibration: applies affine matrix + User Home + backlash. If the bundle includes camera settings, the 'Apply camera settings from cal' button is re-enabled. Use this after a botched re-calibration to get back to a known-good state.</string></property>
               <property name="minimumWidth"><number>100</number></property>
             </widget>
           </item>
          </layout>
         </item>

         <item>
          <layout class="QHBoxLayout" name="calFileButtons">
           <item>
             <widget class="QPushButton" name="saveCalibrationButton">
               <property name="text"><string>Save Calibration As...</string></property>
               <property name="toolTip"><string>Save the current calibration to a named JSON file. Bundles affine matrix + User Home values + motor backlash + current camera AOI / rotation / flip.</string></property>
             </widget>
           </item>
           <item>
             <widget class="QPushButton" name="loadCalibrationButton">
               <property name="text"><string>Load Calibration...</string></property>
               <property name="toolTip"><string>Load a calibration JSON. Applies affine matrix, User Home, and backlash immediately. If the file bundles camera settings, the 'Apply camera settings from cal' button becomes enabled.</string></property>
             </widget>
           </item>
           <item>
             <widget class="QPushButton" name="applyCameraFromCalButton">
               <property name="text"><string>Apply camera settings from cal</string></property>
               <property name="toolTip"><string>Apply the AOI / Start X / Start Y / rotation / flip values bundled with the currently loaded calibration. Use this to revert camera display settings after experimenting with them.</string></property>
               <property name="enabled"><bool>false</bool></property>
             </widget>
           </item>
          </layout>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_calmat">
           <property name="title"><string>Calibration (M·target + b)</string></property>
           <layout class="QGridLayout" name="grid_calmat">
            <item row="0" column="0"><widget class="QLabel" name="lm11"><property name="text"><string>M11</string></property></widget></item>
            <item row="0" column="1"><widget class="QDoubleSpinBox" name="matrix_11"><property name="decimals"><number>3</number></property></widget></item>
            <item row="0" column="2"><widget class="QLabel" name="lm12"><property name="text"><string>M12</string></property></widget></item>
            <item row="0" column="3"><widget class="QDoubleSpinBox" name="matrix_12"><property name="decimals"><number>3</number></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="lm21"><property name="text"><string>M21</string></property></widget></item>
            <item row="1" column="1"><widget class="QDoubleSpinBox" name="matrix_21"><property name="decimals"><number>3</number></property></widget></item>
            <item row="1" column="2"><widget class="QLabel" name="lm22"><property name="text"><string>M22</string></property></widget></item>
            <item row="1" column="3"><widget class="QDoubleSpinBox" name="matrix_22"><property name="decimals"><number>3</number></property></widget></item>
            <item row="2" column="0"><widget class="QLabel" name="lbx"><property name="text"><string>bX</string></property></widget></item>
            <item row="2" column="1"><widget class="QDoubleSpinBox" name="offset_a"><property name="decimals"><number>3</number></property></widget></item>
            <item row="2" column="2"><widget class="QLabel" name="lby"><property name="text"><string>bY</string></property></widget></item>
            <item row="2" column="3"><widget class="QDoubleSpinBox" name="offset_b"><property name="decimals"><number>3</number></property></widget></item>
           </layout>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_move">
           <property name="title"><string>Move / Preview (motor units = mm)</string></property>
           <layout class="QGridLayout" name="grid_move">
            <item row="0" column="0"><widget class="QLabel" name="lx"><property name="text"><string>x:</string></property></widget></item>
            <item row="0" column="1"><widget class="QDoubleSpinBox" name="x"><property name="decimals"><number>5</number></property></widget></item>
            <item row="0" column="2"><widget class="QPushButton" name="move_to_pos"><property name="text"><string>Move to Position</string></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="ly"><property name="text"><string>y:</string></property></widget></item>
            <item row="1" column="1"><widget class="QDoubleSpinBox" name="y"><property name="decimals"><number>5</number></property></widget></item>
            <item row="1" column="2"><widget class="QPushButton" name="preview_pos"><property name="text"><string>Preview Position</string></property></widget></item>
           </layout>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_readouts">
           <property name="title"><string>Readouts</string></property>
           <layout class="QGridLayout" name="grid_readouts">
            <item row="0" column="0"><widget class="QLabel" name="l_motx"><property name="text"><string>Motor x:</string></property></widget></item>
            <item row="0" column="1"><widget class="QLabel" name="motor_x_pos"><property name="text"><string>0.0</string></property></widget></item>
            <item row="0" column="2"><widget class="QProgressBar" name="progress_motor_x_pos"><property name="minimum"><number>0</number></property><property name="maximum"><number>100</number></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="l_moty"><property name="text"><string>Motor y:</string></property></widget></item>
            <item row="1" column="1"><widget class="QLabel" name="motor_y_pos"><property name="text"><string>0.0</string></property></widget></item>
            <item row="1" column="2"><widget class="QProgressBar" name="progress_motor_y_pos"><property name="minimum"><number>0</number></property><property name="maximum"><number>100</number></property></widget></item>
           </layout>
          </widget>
         </item>

         <item>
          <widget class="QGroupBox" name="group_jog">
           <property name="title"><string>Jog (motor units = mm)</string></property>
           <layout class="QGridLayout" name="grid_jog">
            <item row="0" column="0"><widget class="QLabel" name="l_stepx"><property name="text"><string>Step x (motor units):</string></property></widget></item>
            <item row="0" column="1"><widget class="QDoubleSpinBox" name="dx_button"><property name="decimals"><number>5</number></property><property name="value"><double>0.01</double></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="l_stepy"><property name="text"><string>Step y (motor units):</string></property></widget></item>
            <item row="1" column="1"><widget class="QDoubleSpinBox" name="dy_button"><property name="decimals"><number>5</number></property><property name="value"><double>0.01</double></property></widget></item>
            <item row="2" column="1"><widget class="QPushButton" name="jog_up_button_3"><property name="text"><string>Jog Up</string></property></widget></item>
            <item row="3" column="0"><widget class="QPushButton" name="jog_left_button_3"><property name="text"><string>Jog Left</string></property></widget></item>
            <item row="3" column="2"><widget class="QPushButton" name="jog_right_button_3"><property name="text"><string>Jog Right</string></property></widget></item>
            <item row="4" column="1"><widget class="QPushButton" name="jog_down_button_3"><property name="text"><string>Jog Down</string></property></widget></item>
            <item row="5" column="0" colspan="3">
             <widget class="QPushButton" name="clearAllManual"><property name="text"><string>Clear All Manual Points</string></property></widget>
            </item>
            <item row="6" column="0" colspan="3">
             <widget class="QPushButton" name="clearAllRasterManual"><property name="text"><string>Clear All Raster Points</string></property></widget>
            </item>
           </layout>
          </widget>
         </item>
         
         <item>
          <widget class="QGroupBox" name="group_device_home">
           <property name="title"><string>Device Home (mechanical reference)</string></property>
           <property name="toolTip"><string>Kinesis Home(): drives the motor on a SLOW full-travel run to its mechanical limit/reference (can take several seconds). NOT the same as User Home (which just goes to a stored target without homing). Use only when re-zeroing after a power cycle or stall.</string></property>
           <layout class="QGridLayout" name="grid_device_home">
            <item row="0" column="0"><widget class="QPushButton" name="device_home_x"><property name="toolTip"><string>SLOW full-travel mechanical homing of the X motor (Kinesis Home(), can take seconds). Re-zeros the mechanical reference after a power cycle/stall -- NOT 'go to a stored position' (that is User Home Go).</string></property><property name="text"><string>Device Home X</string></property></widget></item>
            <item row="0" column="1"><widget class="QPushButton" name="device_home_y"><property name="toolTip"><string>SLOW full-travel mechanical homing of the Y motor (Kinesis Home(), can take seconds). Re-zeros the mechanical reference after a power cycle/stall -- NOT 'go to a stored position' (that is User Home Go).</string></property><property name="text"><string>Device Home Y</string></property></widget></item>
            <item row="0" column="2"><widget class="QPushButton" name="device_home_both"><property name="toolTip"><string>SLOW full-travel mechanical homing of BOTH motors (Kinesis Home(), can take seconds). Re-zeros the mechanical reference after a power cycle/stall -- NOT 'go to a stored position' (that is User Home Both).</string></property><property name="text"><string>Device Home Both</string></property></widget></item>
           </layout>
          </widget>
         </item>

         <item>
          <widget class="QGroupBox" name="group_user_home">
           <property name="title"><string>User Home (mm; user-defined target position)</string></property>
           <property name="toolTip"><string>User-programmable home: a stored (X, Y) motor target. Set commits the spinbox value as the new stored target without moving the motor; Go moves to the stored value. NOT a coordinate-frame origin — reported positions are unchanged.</string></property>
           <layout class="QGridLayout" name="grid_user_home">
            <item row="0" column="1"><widget class="QLabel" name="luser_home_reading_hdr"><property name="text"><string>Reading</string></property></widget></item>
            <item row="0" column="2"><widget class="QLabel" name="luser_home_setpoint_hdr"><property name="text"><string>Setpoint</string></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="luser_home_x"><property name="text"><string>X:</string></property></widget></item>
            <item row="1" column="1"><widget class="QLabel" name="user_home_x_reading"><property name="text"><string>—</string></property></widget></item>
            <item row="1" column="2"><widget class="QDoubleSpinBox" name="user_home_x_setpoint"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.01</double></property><property name="minimum"><double>-1000.0</double></property><property name="maximum"><double>1000.0</double></property></widget></item>
            <item row="1" column="3"><widget class="QPushButton" name="user_home_x_set"><property name="text"><string>Set</string></property></widget></item>
            <item row="1" column="4"><widget class="QPushButton" name="user_home_x_go"><property name="text"><string>Go</string></property></widget></item>
            <item row="2" column="0"><widget class="QLabel" name="luser_home_y"><property name="text"><string>Y:</string></property></widget></item>
            <item row="2" column="1"><widget class="QLabel" name="user_home_y_reading"><property name="text"><string>—</string></property></widget></item>
            <item row="2" column="2"><widget class="QDoubleSpinBox" name="user_home_y_setpoint"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.01</double></property><property name="minimum"><double>-1000.0</double></property><property name="maximum"><double>1000.0</double></property></widget></item>
            <item row="2" column="3"><widget class="QPushButton" name="user_home_y_set"><property name="text"><string>Set</string></property></widget></item>
            <item row="2" column="4"><widget class="QPushButton" name="user_home_y_go"><property name="text"><string>Go</string></property></widget></item>
            <item row="3" column="0" colspan="5"><widget class="QPushButton" name="user_home_both"><property name="text"><string>User Home Both</string></property></widget></item>
           </layout>
          </widget>
         </item>

         <item>
          <widget class="QGroupBox" name="group_backlash">
           <property name="title"><string>Backlash (motor units = mm)</string></property>
           <property name="toolTip"><string>Reading column shows the live motor backlash. Type a value in Setpoint and press the Set button to send it (typing/arrows alone do nothing). Reading refreshes asynchronously once the motor confirms — even if a Home is in progress, the prompt stays responsive.</string></property>
           <layout class="QGridLayout" name="grid_backlash">
            <item row="0" column="1"><widget class="QLabel" name="lbacklash_reading_hdr"><property name="text"><string>Reading</string></property></widget></item>
            <item row="0" column="2"><widget class="QLabel" name="lbacklash_setpoint_hdr"><property name="text"><string>Setpoint</string></property></widget></item>
            <item row="0" column="3"><widget class="QLabel" name="lbacklash_action_hdr"><property name="text"><string>Action</string></property></widget></item>
            <item row="1" column="0"><widget class="QLabel" name="lbacklash_x"><property name="text"><string>X:</string></property></widget></item>
            <item row="1" column="1"><widget class="QLabel" name="x_backlash_reading"><property name="text"><string>—</string></property></widget></item>
            <item row="1" column="2"><widget class="QDoubleSpinBox" name="x_backlash"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.001</double></property></widget></item>
            <item row="1" column="3"><widget class="QPushButton" name="x_backlash_set"><property name="text"><string>Set</string></property><property name="toolTip"><string>Send the X Setpoint to the motor as the new backlash (non-blocking).</string></property></widget></item>
            <item row="2" column="0"><widget class="QLabel" name="lbacklash_y"><property name="text"><string>Y:</string></property></widget></item>
            <item row="2" column="1"><widget class="QLabel" name="y_backlash_reading"><property name="text"><string>—</string></property></widget></item>
            <item row="2" column="2"><widget class="QDoubleSpinBox" name="y_backlash"><property name="decimals"><number>5</number></property><property name="singleStep"><double>0.001</double></property></widget></item>
            <item row="2" column="3"><widget class="QPushButton" name="y_backlash_set"><property name="text"><string>Set</string></property><property name="toolTip"><string>Send the Y Setpoint to the motor as the new backlash (non-blocking).</string></property></widget></item>
           </layout>
          </widget>
         </item>

         <item>
          <widget class="QGroupBox" name="group_display_options">
           <property name="title"><string>Display Options</string></property>
           <layout class="QGridLayout" name="grid_display_options">
            <item row="0" column="0" colspan="3">
             <widget class="QCheckBox" name="show_current_marker_checkbox">
              <property name="text"><string>Show current position</string></property>
              <property name="checked"><bool>true</bool></property>
             </widget>
            </item>
            <item row="1" column="0">
             <widget class="QCheckBox" name="show_all_points_checkbox">
              <property name="text"><string>Display points</string></property>
             </widget>
            </item>
            <item row="1" column="1"><widget class="QLabel" name="l_pts"><property name="text"><string>Last N:</string></property></widget></item>
            <item row="1" column="2">
             <widget class="QSpinBox" name="point_display_count">
              <property name="minimum"><number>0</number></property>
              <property name="maximum"><number>100000</number></property>
              <property name="value"><number>50</number></property>
             </widget>
            </item>
            <item row="2" column="0">
             <widget class="QCheckBox" name="show_all_raster_points_checkbox">
              <property name="text"><string>Display raster points</string></property>
              <property name="checked"><bool>true</bool></property>
             </widget>
            </item>
            <item row="2" column="1"><widget class="QLabel" name="l_raster_pts"><property name="text"><string>Last N:</string></property></widget></item>
            <item row="2" column="2">
             <widget class="QSpinBox" name="raster_point_display_count">
              <property name="minimum"><number>0</number></property>
              <property name="maximum"><number>1000000</number></property>
              <property name="value"><number>500</number></property>
             </widget>
            </item>
           </layout>
          </widget>
         </item>

         <item><spacer name="manualBottomSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer></item>
        </layout>
       </widget>
      </widget>
      
      <widget class="QWidget" name="rightWidget">
       <layout class="QVBoxLayout" name="verticalLayout_Right">
        <item>
         <widget class="QWidget" name="plot" native="true">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
            <horstretch>1</horstretch>
            <verstretch>10</verstretch>
           </sizepolicy>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QTextEdit" name="textEdit_2">
          <property name="minimumHeight">
           <number>120</number>
          </property>
          <property name="sizePolicy">
           <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
             <horstretch>1</horstretch>
             <verstretch>2</verstretch>
           </sizepolicy>
          </property>
          <property name="readOnly">
           <bool>true</bool>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
  <widget class="QMenuBar" name="menubar"/>
  <widget class="QStatusBar" name="statusbar"/>
 </widget>
